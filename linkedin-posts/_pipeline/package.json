{
  "name": "linkedin-automation-portfolio",
  "version": "1.0.0",
  "description": "LinkedIn post generator from Prismatic YAML exports",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "parse": "node scripts/parse-yaml.js",
    "analyze": "node scripts/analyze-processes.js",
    "generate-map": "node scripts/generate-map.js",
    "audit": "node scripts/audit-yaml.js",
    "stage1:bundles": "node scripts/generate-bundles.js",
    "stage2:posts": "node scripts/generate-posts.js",
    "stage3:diagrams": "node scripts/generate-diagrams.js",
    "pipeline": "npm run stage1:bundles && npm run stage2:posts && npm run stage3:diagrams",
    "pipeline:diagrams-only": "npm run stage3:diagrams"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "fs-extra": "11.3.4",
    "playwright": "^1.59.1",
    "yaml": "2.8.3"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.12.0"
  }
}
